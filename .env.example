# Copy this file to .env.local and fill in the value (optional).
#
# Your scheduling link for the booking page. Works with Cal.com, Calendly, or
# any other scheduling page. This is OPTIONAL: you can also paste the link
# directly into the BOOKING_URL line near the top of src/app/booking/page.tsx.
# If both are set, this environment variable wins.
#
# Example: https://cal.com/your-name/30min
NEXT_PUBLIC_BOOKING_URL=
